{
  "name": "@privasys/drive-sdk",
  "version": "0.2.0",
  "description": "TypeScript client for Privasys Drive — encrypted multi-tenant file storage in TDX.",
  "license": "AGPL-3.0",
  "author": "Privasys",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Privasys/drive.git",
    "directory": "sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/*.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
